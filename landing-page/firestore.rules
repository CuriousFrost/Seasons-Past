rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User documents are private to the owner.
    // Cross-user mutations (accept request, remove friend) go through Cloud
    // Functions that use the admin SDK and bypass these rules.
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Friend ID -> UID lookup table. Any signed-in user can read so they can
    // resolve a Friend ID to a UID before sending a request.
    match /friendIds/{friendId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Friend request inbox. Sender creates the doc directly; recipient (or
    // sender) can delete it; only the two parties can read it. Acceptance
    // goes through the acceptFriendship Cloud Function.
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.from
        && request.resource.data.from != request.resource.data.to
        && requestId == request.resource.data.from + "_" + request.resource.data.to;

      allow read: if request.auth != null
        && (request.auth.uid == resource.data.to
            || request.auth.uid == resource.data.from);

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.to
            || request.auth.uid == resource.data.from);

      // No client updates — recipients accept via Cloud Function.
      allow update: if false;
    }
  }
}
